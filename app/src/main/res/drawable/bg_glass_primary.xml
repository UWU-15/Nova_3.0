<?xml version="1.0" encoding="utf-8"?>

<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- 1. MAIN GLASS BODY -->
    <item>
        <shape>
            <gradient
                android:angle="45"
                android:startColor="#26FFFFFF"
                android:centerColor="#18FFFFFF"
                android:endColor="#12FFFFFF"/>
            <corners android:radius="28dp"/>
        </shape>
    </item>

    <!-- 2. TOP LIGHT (shine) -->
    <item>
        <shape>
            <gradient
                android:angle="270"
                android:startColor="#33FFFFFF"
                android:endColor="#00FFFFFF"/>
            <corners android:radius="28dp"/>
        </shape>
    </item>

    <!-- 3. BOTTOM DEPTH (ВОТ ТО ЧТО ТЫ СПРОСИЛ) -->
    <item android:bottom="0dp">
        <shape>
            <gradient
                android:angle="90"
                android:startColor="#00000000"
                android:centerColor="#1A000000"
                android:endColor="#3B753D8A"/>
            <corners android:radius="28dp"/>
        </shape>
    </item>

</layer-list>