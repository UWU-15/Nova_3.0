<?xml version="1.0" encoding="utf-8"?>

<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_player_gradient"
    android:gravity="center_horizontal"
    android:orientation="vertical"
    android:padding="24dp">

    <ImageView
        android:id="@+id/img_album"
        android:layout_width="300dp"
        android:layout_height="300dp"
        android:layout_marginTop="40dp"
        android:background="@drawable/bg_glass_card"
        android:clipToOutline="true"
        android:elevation="12dp"
        android:scaleType="centerCrop"
        android:src="@drawable/ic_launcher_foreground"/>

    <TextView
        android:id="@+id/txt_song"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:text="Dreamscape"
        android:textColor="@color/text_primary"
        android:textSize="32sp"
        android:textStyle="bold"/>

    <TextView
        android:id="@+id/txt_artist"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Neon Memory"
        android:textColor="@color/accent_light"
        android:textSize="18sp"/>

    <SeekBar
        android:id="@+id/seekBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:progressTint="@color/accent"
        android:thumbTint="@color/accent"/>

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:gravity="center"
        android:orientation="horizontal">

        <ImageButton
            android:id="@+id/btn_prev"
            android:layout_width="58dp"
            android:layout_height="58dp"
            android:background="@drawable/bg_glass_card"
            android:padding="16dp"
            android:src="@drawable/ic_prev"
            app:tint="@android:color/white"/>

        <ImageButton
            android:id="@+id/btn_play"
            android:layout_width="78dp"
            android:layout_height="78dp"
            android:layout_marginHorizontal="24dp"
            android:background="@drawable/bg_glow_button"
            android:padding="20dp"
            android:src="@drawable/ic_play"
            app:tint="@android:color/white"/>

        <ImageButton
            android:id="@+id/btn_next"
            android:layout_width="58dp"
            android:layout_height="58dp"
            android:background="@drawable/bg_glass_card"
            android:padding="16dp"
            android:src="@drawable/ic_next"
            app:tint="@android:color/white"/>

    </LinearLayout>

</LinearLayout>